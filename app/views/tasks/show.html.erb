<% content_for :head do %>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
<% end %>

<style>
  :root { --mono: 'JetBrains Mono', monospace; }
  body { background: #000d06 !important; color: #c8ffe0; font-family: 'Inter', sans-serif; }
  .page-wrap { max-width: 700px; margin: 0 auto; padding: 80px 24px 60px; }
  .card { background: rgba(0,255,136,.03); border: 1px solid rgba(0,255,136,.15); border-radius: 14px; padding: 36px; }
  .task-status { display: inline-flex; align-items: center; gap: 8px; font-family: var(--mono); font-size: .75rem; padding: 6px 14px; border-radius: 9999px; border: 1px solid; margin-bottom: 20px; }
  .status-done { color: #4a7a60; border-color: rgba(74,122,96,.4); background: rgba(74,122,96,.08); }
  .status-pending { color: #00ff88; border-color: rgba(0,255,136,.4); background: rgba(0,255,136,.06); }
  .task-title { font-size: 1.6rem; font-weight: 800; color: #fff; letter-spacing: -.02em; margin-bottom: 16px; }
  .task-desc { font-size: .95rem; color: #7bffb0; line-height: 1.8; white-space: pre-wrap; }
  .task-meta { font-family: var(--mono); font-size: .7rem; color: #2d6644; margin-top: 24px; border-top: 1px solid rgba(0,255,136,.1); padding-top: 16px; }
  .actions { display: flex; gap: 12px; margin-top: 24px; flex-wrap: wrap; }
  .btn { font-family: var(--mono); font-size: .75rem; padding: 10px 22px; border-radius: 8px; text-decoration: none; border: 1px solid; cursor: pointer; background: transparent; transition: all .2s; }
  .btn-edit { color: #ffd980; border-color: rgba(255,217,128,.4); }
  .btn-edit:hover { background: rgba(255,217,128,.08); }
  .btn-del { color: #ff8888; border-color: rgba(255,100,100,.4); }
  .btn-del:hover { background: rgba(255,80,80,.08); }
  .btn-back { color: #69ffb8; border-color: rgba(0,255,136,.3); }
  .btn-back:hover { background: rgba(0,255,136,.08); }
</style>

<div class="page-wrap">
  <div style="font-family:var(--mono);font-size:.7rem;letter-spacing:.2em;text-transform:uppercase;color:#00ff88;margin-bottom:24px;">// tarefa</div>

  <div class="card">
    <div class="task-status <%= @task.done? ? 'status-done' : 'status-pending' %>">
      <span style="width:7px;height:7px;border-radius:50%;background:currentColor;display:inline-block;"></span>
      <%= @task.done? ? "concluída" : "pendente" %>
    </div>

    <div class="task-title"><%= @task.title %></div>

    <% if @task.description.present? %>
      <div class="task-desc"><%= @task.description %></div>
    <% else %>
      <div style="font-family:var(--mono);font-size:.8rem;color:#2d6644;font-style:italic;">sem descrição</div>
    <% end %>

    <div class="task-meta">
      criada em <%= @task.created_at.strftime("%d/%m/%Y %H:%M") %>
      &nbsp;·&nbsp; atualizada em <%= @task.updated_at.strftime("%d/%m/%Y %H:%M") %>
    </div>
  </div>

  <div class="actions">
    <%= link_to "← Lista", tasks_path, class: "btn btn-back" %>
    <%= link_to "Editar", edit_task_path(@task), class: "btn btn-edit" %>
    <%= button_to "Remover", task_path(@task), method: :delete, class: "btn btn-del",
        form: { data: { turbo_confirm: "Remover esta tarefa?" } } %>
  </div>
</div>
