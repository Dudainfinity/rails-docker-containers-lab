<%# ─── canvas precisa ficar fora do layout normal, injetamos via content_for ─── %>
<% content_for :head do %>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
<% end %>

<%
  db_ok = begin
    ActiveRecord::Base.connection.execute("SELECT version();").first["version"]
  rescue => e
    nil
  end
  task_count = Task.count rescue 0
%>

<canvas id="bg-canvas" style="position:fixed;inset:0;z-index:0;pointer-events:none;"></canvas>

<div style="position:relative;z-index:2;">

<%# ─── SCANLINES overlay ─── %>
<div style="position:fixed;inset:0;z-index:1;pointer-events:none;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,0.07) 2px,rgba(0,0,0,0.07) 4px);"></div>

<%# ─── NAV ─── %>
<nav style="position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:14px 40px;background:rgba(0,13,6,0.88);backdrop-filter:blur(20px);border-bottom:1px solid rgba(0,255,136,0.1);">
  <span style="font-family:var(--mono);font-size:.85rem;color:#00ff88;"><span style="color:#fff">&gt;_ </span>rails-docker-lab</span>
  <div style="display:flex;gap:24px;">
    <a href="#arch"   style="font-family:var(--mono);font-size:.72rem;color:#6bffa0;text-decoration:none;letter-spacing:.1em;text-transform:uppercase;">Arquitetura</a>
    <a href="#status" style="font-family:var(--mono);font-size:.72rem;color:#6bffa0;text-decoration:none;letter-spacing:.1em;text-transform:uppercase;">Status</a>
    <a href="#run"    style="font-family:var(--mono);font-size:.72rem;color:#6bffa0;text-decoration:none;letter-spacing:.1em;text-transform:uppercase;">Como Rodar</a>
  </div>
  <span style="font-family:var(--mono);font-size:.7rem;padding:4px 12px;border:1px solid #00ff88;border-radius:4px;color:#00ff88;box-shadow:0 0 10px rgba(0,255,136,.3);">Rails <%= Rails.version %></span>
</nav>

<%# ─── HERO ─── %>
<div style="min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:120px 24px 80px;position:relative;z-index:2;">
  <div style="font-family:'JetBrains Mono',monospace;font-size:.75rem;letter-spacing:.25em;text-transform:uppercase;color:#00ff88;margin-bottom:28px;display:flex;align-items:center;gap:12px;">
    <span style="width:40px;height:1px;background:#00ff88;box-shadow:0 0 10px rgba(0,255,136,.5);display:inline-block;"></span>
    containerização full-stack
    <span style="width:40px;height:1px;background:#00ff88;box-shadow:0 0 10px rgba(0,255,136,.5);display:inline-block;"></span>
  </div>

  <h1 style="font-family:'Inter',sans-serif;font-size:clamp(2.8rem,7vw,5.5rem);font-weight:900;line-height:1.05;letter-spacing:-.03em;margin-bottom:24px;color:#fff;">
    rails-docker-<br><span style="color:#00ff88;text-shadow:0 0 40px rgba(0,255,136,.6),0 0 100px rgba(0,255,136,.2);">containers-lab</span>
  </h1>

  <p style="max-width:580px;font-size:1.05rem;color:#7bffb0;line-height:1.8;margin-bottom:40px;">
    Aplicação Ruby on Rails containerizada com Docker e Docker Compose —
    ambiente isolado, reproduzível e pronto para escalar.
  </p>

  <div id="typed-out" style="font-family:'JetBrains Mono',monospace;font-size:.9rem;color:#00e676;margin-bottom:44px;min-height:1.4em;"></div>

  <div style="display:flex;flex-wrap:wrap;gap:10px;justify-content:center;margin-bottom:56px;">
    <% %w[Ruby\ on\ Rails\ 8.1 PostgreSQL\ 15 Docker Docker\ Compose Volumes Networks Linux Git].each do |t| %>
      <span style="font-family:'JetBrains Mono',monospace;font-size:.72rem;padding:6px 16px;border-radius:9999px;border:1px solid rgba(0,255,136,.35);background:rgba(0,255,136,.06);color:#69ffb8;letter-spacing:.05em;"><%= t %></span>
    <% end %>
  </div>

  <div style="display:flex;flex-direction:column;align-items:center;gap:8px;color:#2a8a55;font-size:.72rem;font-family:'JetBrains Mono',monospace;letter-spacing:.1em;">
    <div style="width:1px;height:50px;background:linear-gradient(to bottom,#00ff88,transparent);animation:spulse 2s ease-in-out infinite;"></div>
    <span>scroll</span>
  </div>
</div>

<%# ─── STAT BAR ─── %>
<div style="max-width:1100px;margin:0 auto;padding:0 24px 80px;position:relative;z-index:2;">
  <div class="fade-in" style="display:flex;flex-wrap:wrap;border:1px solid rgba(0,255,136,.15);border-radius:14px;overflow:hidden;">
    <% [
      ["2",            "Containers"],
      ["2",            "Volumes"],
      ["1",            "Network Bridge"],
      ["3000",         "Porta Exposta"],
      [task_count.to_s,"Tarefas criadas"],
    ].each_with_index do |(num, lbl), i| %>
      <div style="flex:1;min-width:140px;padding:28px 20px;text-align:center;background:rgba(0,255,136,.03);border-right:<%= i < 4 ? "1px solid rgba(0,255,136,.1)" : "none" %>;">
        <span style="font-family:'JetBrains Mono',monospace;font-size:2rem;font-weight:700;color:#00ff88;text-shadow:0 0 20px rgba(0,255,136,.5),0 0 60px rgba(0,255,136,.15);display:block;" data-target="<%= num %>">0</span>
        <div style="font-size:.75rem;color:#4a9966;letter-spacing:.05em;margin-top:4px;"><%= lbl %></div>
      </div>
    <% end %>
  </div>
</div>

<%# ─── ARQUITETURA ─── %>
<div style="border-top:1px solid rgba(0,255,136,.07);border-bottom:1px solid rgba(0,255,136,.07);background:#011a0e;" id="arch">
  <div style="max-width:1100px;margin:0 auto;padding:80px 24px;position:relative;z-index:2;">
    <div class="fade-in">
      <div style="font-family:'JetBrains Mono',monospace;font-size:.7rem;letter-spacing:.2em;text-transform:uppercase;color:#00ff88;margin-bottom:12px;">// infraestrutura</div>
      <h2 style="font-size:clamp(1.8rem,3.5vw,2.6rem);font-weight:800;color:#fff;margin-bottom:14px;letter-spacing:-.02em;">Arquitetura dos <span style="color:#00ff88;">Containers</span></h2>
      <p style="color:#5baf82;font-size:.95rem;max-width:520px;line-height:1.7;margin-bottom:48px;">Fluxo de comunicação entre usuário, aplicação e banco de dados.</p>
    </div>

    <div class="fade-in" style="position:relative;border:1px solid rgba(0,255,136,.15);border-radius:20px;padding:50px 32px;background:linear-gradient(135deg,rgba(0,255,136,.02),rgba(0,13,6,.8));overflow:hidden;">
      <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(0,255,136,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(0,255,136,.04) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;"></div>

      <div style="display:flex;align-items:center;justify-content:center;flex-wrap:wrap;gap:10px;position:relative;z-index:1;">
        <% [
          ["cliente",       "Browser",            "localhost"],
          ["porta 3000",    "rails_app",           "Rails 8.1 + Puma"],
          ["rails_network", "rails_postgres_db",   "PostgreSQL 15 :5432"],
          ["volume",        "postgres_data",       "dados persistidos"],
        ].each_with_index do |(lbl, name, detail), i| %>
          <div style="background:rgba(0,13,6,.9);border:1px solid rgba(0,255,136,.3);border-radius:12px;padding:18px 22px;text-align:center;min-width:130px;transition:all .3s;">
            <div style="font-family:'JetBrains Mono',monospace;font-size:.6rem;letter-spacing:.12em;text-transform:uppercase;color:#2a7a50;margin-bottom:5px;"><%= lbl %></div>
            <div style="font-size:.9rem;font-weight:700;color:#00ff88;text-shadow:0 0 12px rgba(0,255,136,.5);"><%= name %></div>
            <div style="font-family:'JetBrains Mono',monospace;font-size:.7rem;color:#4a8f68;margin-top:3px;"><%= detail %></div>
          </div>
          <% if i < 3 %>
            <div style="display:flex;align-items:center;">
              <div style="width:28px;height:1px;background:linear-gradient(90deg,rgba(0,255,136,.3),#00ff88);position:relative;">
                <div style="position:absolute;right:-1px;top:-3px;border:3px solid transparent;border-left-color:#00ff88;border-right:none;filter:drop-shadow(0 0 4px #00ff88);"></div>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>

    <%# lista simples pedida ─ fica abaixo do diagrama %>
    <div class="fade-in" style="margin-top:32px;background:rgba(0,255,136,.04);border:1px solid rgba(0,255,136,.15);border-radius:12px;padding:28px 32px;">
      <h3 style="font-size:1rem;font-weight:700;color:#00ff88;margin-bottom:16px;">Componentes</h3>
      <ul style="list-style:none;display:flex;flex-direction:column;gap:10px;">
        <li style="font-size:.88rem;color:#c8ffe0;display:flex;gap:10px;align-items:center;"><span style="color:#00ff88;font-family:'JetBrains Mono',monospace;">▸</span> Container Rails (web) — aplicação Ruby on Rails 8.1 servida pelo Puma na porta 3000</li>
        <li style="font-size:.88rem;color:#c8ffe0;display:flex;gap:10px;align-items:center;"><span style="color:#00ff88;font-family:'JetBrains Mono',monospace;">▸</span> Container PostgreSQL (db) — banco de dados isolado, acessível apenas na rede interna</li>
        <li style="font-size:.88rem;color:#c8ffe0;display:flex;gap:10px;align-items:center;"><span style="color:#00ff88;font-family:'JetBrains Mono',monospace;">▸</span> Network bridge (rails_network) — rede isolada que conecta os dois containers por nome de serviço</li>
      </ul>
    </div>
  </div>
</div>

<%# ─── STATUS ─── %>
<div style="max-width:1100px;margin:0 auto;padding:80px 24px;position:relative;z-index:2;" id="status">
  <div class="fade-in">
    <div style="font-family:'JetBrains Mono',monospace;font-size:.7rem;letter-spacing:.2em;text-transform:uppercase;color:#00ff88;margin-bottom:12px;">// runtime</div>
    <h2 style="font-size:clamp(1.8rem,3.5vw,2.6rem);font-weight:800;color:#fff;margin-bottom:40px;letter-spacing:-.02em;">Status <span style="color:#00ff88;">em Tempo Real</span></h2>
  </div>

  <div class="fade-in" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:16px;">
    <div style="background:rgba(0,255,136,.04);border:1px solid rgba(0,255,136,.2);border-radius:12px;padding:24px;">
      <div style="font-family:'JetBrains Mono',monospace;font-size:.68rem;letter-spacing:.1em;text-transform:uppercase;color:#2a7a50;margin-bottom:10px;">Rails</div>
      <div style="font-size:1.3rem;font-weight:800;color:#00ff88;"><%= Rails.version %></div>
    </div>
    <div style="background:rgba(0,255,136,.04);border:1px solid rgba(0,255,136,.2);border-radius:12px;padding:24px;">
      <div style="font-family:'JetBrains Mono',monospace;font-size:.68rem;letter-spacing:.1em;text-transform:uppercase;color:#2a7a50;margin-bottom:10px;">Ruby</div>
      <div style="font-size:1.3rem;font-weight:800;color:#00ff88;"><%= RUBY_VERSION %></div>
    </div>
    <div style="background:rgba(0,255,136,.04);border:1px solid rgba(0,255,136,.2);border-radius:12px;padding:24px;">
      <div style="font-family:'JetBrains Mono',monospace;font-size:.68rem;letter-spacing:.1em;text-transform:uppercase;color:#2a7a50;margin-bottom:10px;">Ambiente</div>
      <div style="font-size:1.3rem;font-weight:800;color:#00ff88;"><%= Rails.env %></div>
    </div>
    <div style="background:<%= db_ok ? "rgba(0,255,136,.04)" : "rgba(255,50,50,.05)" %>;border:1px solid <%= db_ok ? "rgba(0,255,136,.2)" : "rgba(255,80,80,.3)" %>;border-radius:12px;padding:24px;">
      <div style="font-family:'JetBrains Mono',monospace;font-size:.68rem;letter-spacing:.1em;text-transform:uppercase;color:#2a7a50;margin-bottom:10px;">PostgreSQL</div>
      <% if db_ok %>
        <div style="display:flex;align-items:center;gap:8px;">
          <span style="width:8px;height:8px;border-radius:50%;background:#00ff88;box-shadow:0 0 8px #00ff88;display:inline-block;"></span>
          <span style="font-size:.9rem;font-weight:700;color:#00ff88;">✔ conectado</span>
        </div>
      <% else %>
        <span style="font-size:.9rem;font-weight:700;color:#ff5555;">✘ erro</span>
      <% end %>
    </div>
    <div style="background:rgba(0,255,136,.04);border:1px solid rgba(0,255,136,.2);border-radius:12px;padding:24px;">
      <div style="font-family:'JetBrains Mono',monospace;font-size:.68rem;letter-spacing:.1em;text-transform:uppercase;color:#2a7a50;margin-bottom:10px;">Rails rodando</div>
      <div style="display:flex;align-items:center;gap:8px;">
        <span style="width:8px;height:8px;border-radius:50%;background:#00ff88;box-shadow:0 0 8px #00ff88;display:inline-block;animation:pulse 2s ease-in-out infinite;"></span>
        <span style="font-size:.9rem;font-weight:700;color:#00ff88;">✔ online</span>
      </div>
    </div>
    <div style="background:rgba(0,255,136,.04);border:1px solid rgba(0,255,136,.2);border-radius:12px;padding:24px;">
      <div style="font-family:'JetBrains Mono',monospace;font-size:.68rem;letter-spacing:.1em;text-transform:uppercase;color:#2a7a50;margin-bottom:10px;">Tarefas no banco</div>
      <div style="font-size:1.3rem;font-weight:800;color:#00ff88;"><%= task_count %> <%= link_to "(ver)", tasks_path, style:"font-size:.75rem;color:#69ffb8;" %></div>
    </div>
  </div>
</div>

<%# ─── COMO RODAR ─── %>
<div style="border-top:1px solid rgba(0,255,136,.07);border-bottom:1px solid rgba(0,255,136,.07);background:#011a0e;" id="run">
  <div style="max-width:1100px;margin:0 auto;padding:80px 24px;position:relative;z-index:2;">
    <div class="fade-in">
      <div style="font-family:'JetBrains Mono',monospace;font-size:.7rem;letter-spacing:.2em;text-transform:uppercase;color:#00ff88;margin-bottom:12px;">// getting started</div>
      <h2 style="font-size:clamp(1.8rem,3.5vw,2.6rem);font-weight:800;color:#fff;margin-bottom:14px;letter-spacing:-.02em;">Como <span style="color:#00ff88;">Rodar</span></h2>
      <p style="color:#5baf82;font-size:.95rem;max-width:520px;line-height:1.7;margin-bottom:48px;">Três comandos para ter o ambiente completo rodando.</p>
    </div>

    <div class="fade-in" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:14px;margin-bottom:40px;">
      <% [
        ["01 — clonar",  "git clone <repo>"],
        ["02 — build",   "docker compose build"],
        ["03 — subir",   "docker compose up"],
        ["acessar",      "http://localhost:3000"],
        ["logs",         "docker compose logs -f web"],
        ["parar",        "docker compose down"],
      ].each do |label, cmd| %>
        <div style="background:#000e07;border:1px solid rgba(0,255,136,.15);border-radius:10px;padding:18px 20px;">
          <div style="font-family:'JetBrains Mono',monospace;font-size:.68rem;letter-spacing:.1em;text-transform:uppercase;color:#2d7a50;margin-bottom:8px;"><%= label %></div>
          <code style="font-family:'JetBrains Mono',monospace;font-size:.83rem;color:#00ff88;"><%= cmd %></code>
        </div>
      <% end %>
    </div>

    <%# terminal bash %>
    <div class="fade-in" style="background:#000e07;border:1px solid rgba(0,255,136,.2);border-radius:14px;overflow:hidden;box-shadow:0 0 60px rgba(0,0,0,.8),0 0 30px rgba(0,255,136,.06);">
      <div style="display:flex;align-items:center;padding:12px 20px;background:rgba(0,255,136,.05);border-bottom:1px solid rgba(0,255,136,.12);gap:8px;">
        <div style="width:11px;height:11px;border-radius:50%;background:#ff5f57;"></div>
        <div style="width:11px;height:11px;border-radius:50%;background:#febc2e;"></div>
        <div style="width:11px;height:11px;border-radius:50%;background:#28c840;"></div>
        <span style="font-family:'JetBrains Mono',monospace;font-size:.75rem;color:#3a7a55;margin-left:8px;">bash</span>
      </div>
      <pre style="padding:24px 32px;font-family:'JetBrains Mono',monospace;font-size:.82rem;line-height:2;overflow-x:auto;color:#4a9060;"><span style="color:#2a6642;font-style:italic;"># build e inicialização completa</span>
<span style="color:#00ff88;">$ </span><span style="color:#c8ffe0;">docker compose up --build</span>

<span style="color:#2a6642;font-style:italic;"># verificar containers em execução</span>
<span style="color:#00ff88;">$ </span><span style="color:#c8ffe0;">docker compose ps</span>
<span style="color:#2a6642;">NAME                  STATUS         PORTS</span>
<span style="color:#ffd980;">rails_app</span>             Up (healthy)   0.0.0.0:3000->3000/tcp
<span style="color:#ffd980;">rails_postgres_db</span>     Up (healthy)   5432/tcp

<span style="color:#2a6642;font-style:italic;"># abrir console Rails no container</span>
<span style="color:#00ff88;">$ </span><span style="color:#c8ffe0;">docker compose exec web rails console</span>

<span style="color:#2a6642;font-style:italic;"># inspecionar a network</span>
<span style="color:#00ff88;">$ </span><span style="color:#c8ffe0;">docker network inspect rails_network</span></pre>
    </div>
  </div>
</div>

<%# ─── FOOTER ─── %>
<footer style="border-top:1px solid rgba(0,255,136,.1);padding:60px 24px;text-align:center;position:relative;z-index:2;">
  <div style="position:absolute;bottom:0;left:50%;transform:translateX(-50%);width:300px;height:150px;background:radial-gradient(ellipse at bottom,rgba(0,255,136,.12),transparent 70%);pointer-events:none;"></div>
  <div style="font-family:'JetBrains Mono',monospace;font-size:1.3rem;font-weight:700;color:#00ff88;text-shadow:0 0 20px rgba(0,255,136,.5),0 0 60px rgba(0,255,136,.15);margin-bottom:14px;">&gt;_ rails-docker-containers-lab</div>
  <p style="font-size:.85rem;color:#2d6644;letter-spacing:.05em;">
    Desenvolvido por <span style="color:#69ffb8;">Maria Eduarda</span> &bull;
    Ruby on Rails &bull; PostgreSQL &bull; Docker &bull; Docker Compose
  </p>
  <div style="margin-top:24px;display:flex;gap:14px;justify-content:center;flex-wrap:wrap;">
    <%= link_to "← Home", root_path, style:"display:inline-block;padding:10px 22px;background:#059669;color:#fff;border-radius:8px;text-decoration:none;font-size:.85rem;font-weight:700;" %>
    <%= link_to "Tarefas →", tasks_path, style:"display:inline-block;padding:10px 22px;background:rgba(0,255,136,.1);color:#00ff88;border:1px solid rgba(0,255,136,.4);border-radius:8px;text-decoration:none;font-size:.85rem;font-weight:700;" %>
  </div>
</footer>

</div><%# /wrap %>

<style>
  :root { --mono: 'JetBrains Mono', monospace; }
  body  { background: #000d06 !important; color: #c8ffe0; }
  .fade-in { opacity:0; transform:translateY(28px); transition:opacity .7s ease,transform .7s ease; }
  .fade-in.visible { opacity:1; transform:translateY(0); }
  @keyframes spulse { 0%,100%{opacity:.3;transform:scaleY(1)} 50%{opacity:1;transform:scaleY(1.2)} }
  @keyframes pulse  { 0%,100%{opacity:1} 50%{opacity:.4} }
</style>

<script>
(function(){
  // ── canvas particles ──
  const cv = document.getElementById('bg-canvas');
  const cx = cv.getContext('2d');
  let W, H, pts = [];
  function rs(){ W = cv.width = innerWidth; H = cv.height = innerHeight; }
  function Pt(){ this.x=Math.random()*W; this.y=Math.random()*H; this.vx=(Math.random()-.5)*.4; this.vy=(Math.random()-.5)*.4; this.r=Math.random()*1.4+.3; this.a=Math.random()*.5+.1; }
  function init(n){ pts=[]; for(let i=0;i<n;i++) pts.push(new Pt()); }
  function draw(){
    cx.clearRect(0,0,W,H);
    for(let i=0;i<pts.length;i++) for(let j=i+1;j<pts.length;j++){
      const dx=pts[i].x-pts[j].x, dy=pts[i].y-pts[j].y, d=Math.sqrt(dx*dx+dy*dy);
      if(d<120){ cx.beginPath(); cx.moveTo(pts[i].x,pts[i].y); cx.lineTo(pts[j].x,pts[j].y); cx.strokeStyle=`rgba(0,255,136,${.06*(1-d/120)})`; cx.lineWidth=.5; cx.stroke(); }
    }
    pts.forEach(p=>{ cx.beginPath(); cx.arc(p.x,p.y,p.r,0,Math.PI*2); cx.fillStyle=`rgba(0,255,136,${p.a})`; cx.fill(); p.x+=p.vx; p.y+=p.vy; if(p.x<0||p.x>W)p.vx*=-1; if(p.y<0||p.y>H)p.vy*=-1; });
    requestAnimationFrame(draw);
  }
  rs(); init(75); draw();
  addEventListener('resize',()=>{ rs(); init(75); });

  // ── typed ──
  const phrases=['docker compose up --build','rails db:prepare','docker compose ps','docker network inspect rails_network'];
  const el=document.getElementById('typed-out');
  let pi=0,ci=0,del=false;
  function type(){
    const p=phrases[pi];
    el.innerHTML=(del?p.slice(0,ci):p.slice(0,ci))+'<span style="display:inline-block;width:2px;height:1em;background:#00ff88;margin-left:2px;vertical-align:middle;animation:blink 1s step-end infinite;"></span>';
    if(!del){ ci++; if(ci>p.length){del=true;setTimeout(type,1800);return;} }
    else { ci--; if(ci<0){del=false;pi=(pi+1)%phrases.length;ci=0;} }
    setTimeout(type,del?40:60);
  }
  type();

  // ── counters + fade-in ──
  const obs=new IntersectionObserver(entries=>entries.forEach(e=>{
    if(!e.isIntersecting)return;
    e.target.classList.add('visible');
    e.target.querySelectorAll('[data-target]').forEach(n=>{
      const tgt=parseInt(n.dataset.target)||0;
      const t0=performance.now();
      const dur=tgt>100?1600:900;
      (function tick(now){ const t=Math.min((now-t0)/dur,1); n.textContent=Math.round((1-Math.pow(1-t,3))*tgt); if(t<1)requestAnimationFrame(tick); })(t0);
    });
    obs.unobserve(e.target);
  }),{threshold:.12});
  document.querySelectorAll('.fade-in').forEach(el=>obs.observe(el));
})();
</script>
<style>@keyframes blink{0%,100%{opacity:1}50%{opacity:0}}</style>

